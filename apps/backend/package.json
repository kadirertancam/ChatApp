{
  "name": "@app/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm,cjs --dts --splitting",
    "start": "node dist/index.js",
    "db:migrate": "prisma migrate deploy",
    "db:dev": "prisma migrate dev --name init --create-only && prisma migrate deploy",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.19.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "socket.io": "^4.7.5",
    "zod": "^3.23.8",
    "ioredis": "^5.4.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.5.4",
    "prisma": "^5.19.1",
    "tsup": "^8.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  }
}